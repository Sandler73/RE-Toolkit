yarn.lock
pnpm-lock.yaml
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.node_repl_history

# -----------------------------------------------------------------------------
# Rust and Go, present via optional analysis tooling
# -----------------------------------------------------------------------------
target/
Cargo.lock
*.rs.bk
go.sum.bak
vendor/

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
*.swp
*.swo
*.swn
*~
.#*
\#*#
tmp/
temp/
scratch/

