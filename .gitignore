# -----------------------------------------------------------------------------
*.sh.bak
*.sh.orig
*.sh.rej
*.bash_history
.sh_history
nohup.out
core
core.[0-9]*
*.core
*.stackdump

# -----------------------------------------------------------------------------
# PowerShell
# -----------------------------------------------------------------------------
*.ps1.bak
*.ps1xml.bak
*.psd1.bak
*.psm1.bak
PSScriptAnalyzerSettings.user.psd1
*.pssproj.user

# -----------------------------------------------------------------------------
