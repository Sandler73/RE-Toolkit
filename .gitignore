# =============================================================================
# .gitignore
# =============================================================================
#
# Two concerns are handled here, and the second matters more than usual.
#
# Hygiene: the ordinary build, cache, editor, and OS artifacts.
#
# Safety: RE-Toolkit analyzes hostile binaries. Analysis output contains strings,
# carved files, and extracted resources taken from malware, and committing that
# to a public repository would publish malicious content. Analysis input and
# output are therefore ignored as a safety control, not merely as tidiness.
# Sample binaries are ignored for the same reason.
#
# Version: 3.7.3 - 2026-05-03
# =============================================================================

# -----------------------------------------------------------------------------
# Analysis input and output (safety control)
# -----------------------------------------------------------------------------
out/
output/
re-analysis-out/
results/
analysis/
*_report.html
*_summary.json
*_verdict.txt
_run.json
_similarity-matrix.json
_input/
90-logs/

# Sample and target binaries. Never commit anything you analyzed.
samples/
targets/
malware/
specimens/
quarantine/
_quarantine/

# Executable and library formats
*.exe
*.dll
*.sys
*.ocx
*.cpl
*.scr
*.msi
*.msix
*.appx
*.so
*.so.*
*.dylib
*.a
*.lib
*.o
*.obj
*.elf
*.bin
*.axf
*.prx
*.puff

# Managed, mobile, and bytecode formats
*.apk
*.aab
*.dex
*.odex
*.jar
*.war
*.ear
*.class
*.pyc
*.pyo
*.wasm

# Archives and disk images. In this project these are nearly always analysis
# input rather than project assets.
*.zip
*.tar
*.tar.*
*.tgz
*.gz
*.bz2
*.xz
*.7z
*.rar
*.cab
*.iso
*.img
*.vmdk
*.vhd
*.vhdx
*.dmg
*.pkg
*.deb
*.rpm

# Documents commonly used as malicious carriers
*.doc
*.docm
*.xls
*.xlsm
*.ppt
*.pptm
*.rtf
*.one
*.lnk

# Test fixtures are built at runtime, never committed. If a fixture ever does
# need to be tracked, add a negation for that specific path.
tests/fixtures/*
!tests/fixtures/.gitkeep

# -----------------------------------------------------------------------------
