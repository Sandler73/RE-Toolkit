# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.ppk
credentials
credentials.json
secrets.json
.netrc
.htpasswd

# -----------------------------------------------------------------------------
# Documentation build output
# -----------------------------------------------------------------------------
site/
_site/
docs/_build/
docs/.doctrees/
*.pdf.tmp

# -----------------------------------------------------------------------------
# Ghidra
# -----------------------------------------------------------------------------
*.gpr
*.rep/
*.lock
ghidra_scripts/
.ghidra/
